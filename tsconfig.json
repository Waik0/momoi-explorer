{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "momoi-explorer": ["./src/index.ts"],
      "momoi-explorer/react": ["./src/react/index.ts"],
      "momoi-explorer/ui": ["./src/ui/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "examples"]
}
