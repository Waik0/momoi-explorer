{
  "name": "momoi-explorer",
  "version": "0.1.0",
  "description": "A headless file explorer component with React bindings and default UI",
  "author": "Waik0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./ui": {
      "import": {
        "types": "./dist/ui.d.ts",
        "default": "./dist/ui.js"
      },
      "require": {
        "types": "./dist/ui.d.cts",
        "default": "./dist/ui.cjs"
      }
    },
    "./ui/style.css": "./dist/ui/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "demo:browser": "npm run build && cd examples/browser-demo && npm install && npm run dev",
    "demo:electron": "npm run build && cd examples/electron-app && npm install && npm run dev"
  },
  "keywords": [
    "file-explorer",
    "tree-view",
    "headless-ui",
    "react",
    "electron",
    "vscode"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "react-virtuoso": "^4.18.3"
  }
}
